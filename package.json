{
  "name": "hookdash",
  "version": "0.1.2",
  "description": "Zero-config, self-hosted webhook gateway with a beautiful dashboard. Receive, queue, retry, and monitor webhooks.",
  "keywords": ["webhook", "gateway", "self-hosted", "dashboard", "retry", "queue", "stripe", "github"],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/me-npm/hookdash.git"
  },
  "bugs": {
    "url": "https://github.com/me-npm/hookdash/issues"
  },
  "homepage": "https://github.com/me-npm/hookdash#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hookdash": "dist/index.js"
  },
  "files": [
    "dist",
    "dashboard/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts -- start",
    "build": "npm run build:server && npm run build:dashboard",
    "build:server": "tsup",
    "build:dashboard": "cd dashboard && npm run build",
    "start": "node dist/index.js start",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fastify": "^5.2.1",
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.1.0",
    "fastify-raw-body": "^5.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2",
    "nanoid": "^5.1.2",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "eslint": "^9.17.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
